# Supabase — copy to .env and fill in from your Supabase project settings
# (Project Settings → API). Both values are client-safe: the anon key is a
# public credential gated server-side by Row Level Security.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Backend API — the location/notification endpoints do not exist yet, so leave
# EXPO_PUBLIC_API_BASE_URL blank to run against in-code mocks. Set it to the
# deployed API origin (e.g. https://api.example.com) once the backend is ready.
EXPO_PUBLIC_API_BASE_URL=
# Force mock mode even when a base URL is set. Mock mode is already on whenever
# the base URL is blank, so this is only needed to mock against a real origin.
EXPO_PUBLIC_USE_MOCK_API=
