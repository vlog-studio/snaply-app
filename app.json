{
  "expo": {
    "name": "Snaply",
    "slug": "snaply-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "snaplyapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.anonymous.snaplyapp",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FF6B35",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.snaplyapp",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Snaply가 영상을 촬영할 수 있도록 카메라 접근을 허용해 주세요.",
          "microphonePermission": "Snaply가 영상에 소리를 녹음할 수 있도록 마이크 접근을 허용해 주세요.",
          "recordAudioAndroid": true,
          "barcodeScannerEnabled": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FF6B35",
          "image": "./assets/images/brand-glyph-white.png",
          "imageWidth": 150
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Snaply가 주변 촬영 스팟을 추천해 드릴 수 있도록 위치 접근을 허용해 주세요.",
          "locationAlwaysAndWhenInUsePermission": "앱을 보고 있지 않아도 주변 스팟에 도착하면 알림을 보내드리기 위해 '항상 허용' 위치 권한이 필요해요.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      "expo-video",
      "expo-sharing",
      "expo-secure-store",
      "expo-image",
      "expo-status-bar",
      "expo-web-browser",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "./plugins/with-gradle-jvmargs.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
